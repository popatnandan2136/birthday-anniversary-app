{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.cjs": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "env": {
    "VITE_API_URL": "/api"
  }
}
